PRD.md
settings/
# ──────────────────────────────────────────────────────────────────────────────
# 1. Stacks / Clarinet Secrets
#    Wallet mnemonics, deployment configs with deployer keys, and contract
#    deployment receipts that reference funded wallets.
# ──────────────────────────────────────────────────────────────────────────────

# Wallet mnemonic / seed files generated by Clarinet or manual key management
**/keychain
**/mnemonic
**/seed
**/keychain.json
**/mnemonic.json
**/seed.json
**/keychain.txt
**/mnemonic.txt
**/seed.txt

# Mainnet deployment config — contains deployer addresses and private keys
**/Mainnet.toml
**/mainnet.toml

# Any TOML config with secrets or private deployment parameters
*.secret.toml
*.private.toml

# Deployment receipts for mainnet/testnet — may embed contract addresses tied to funded wallets
# NOTE: devnet deployment receipts are generally safe to track, but mainnet and
# testnet receipts should be carefully reviewed before committing, as they may
# reference funded wallet addresses and deployment keys.
# mainnet receipts reference funded wallets - never commit
contracts/deployments/mainnet.yaml
**/deployments/mainnet*
**/deployments/testnet*

# Deployment plan files that may contain private key references
**/deployment_plans/**/mainnet*
**/deployment_plans/**/testnet*


# ──────────────────────────────────────────────────────────────────────────────
# 2. Environment Variable Files
#    All .env variants that may hold API keys, database URLs, or secrets.
#    .env.example and .env.template are safe — they hold placeholder values only.
# ──────────────────────────────────────────────────────────────────────────────

.env
.env.local
.env.development
.env.development.local
.env.production
.env.production.local
.env.test
.env.test.local
.env.staging
.env.staging.local

# Catch-all for any .env variant not listed above
.env.*

# Re-include safe template files (these contain no real values)
!.env.example
!.env.template

# Ensure .env files in workspaces are still ignored (override re-include patterns)
apps/**/.env
apps/**/.env.*
!apps/**/.env.example
!apps/**/.env.template
contracts/.env
contracts/.env.*
!contracts/.env.example
!contracts/.env.template
packages/**/.env
packages/**/.env.*
!packages/**/.env.example
!packages/**/.env.template


# ──────────────────────────────────────────────────────────────────────────────
# 3. Private Keys and Cryptographic Material
#    Raw key files, wallet exports, certificates, and keystores.
# ──────────────────────────────────────────────────────────────────────────────

# Named key files — any file explicitly named after key material
**/privatekey
**/privatekey.*
**/private_key
**/private_key.*
**/secret_key
**/secret_key.*
**/keystore
**/keystore.*

# Wallet export files (Stacks / Bitcoin wallet backups)
**/wallet.json
*.wallet
# WIF (Wallet Import Format) key exports — raw Bitcoin/Stacks private keys
*.wif

# TLS/SSL certificates and key files
*.pem
*.key
# PKCS#12 key bundles (combined cert + private key)
*.p12
*.pfx
# Java KeyStore files
*.jks

# Hardware wallet backup / recovery files
**/hw-wallet-backup*
**/ledger-backup*
**/trezor-backup*


# ──────────────────────────────────────────────────────────────────────────────
# 4. npm / Package Manager Secrets
#    Auth tokens for npm, Yarn, and other registries.
# ──────────────────────────────────────────────────────────────────────────────

# .npmrc files may contain //registry.npmjs.org/:_authToken — always exclude.
# NOTE: If you need a root-level .npmrc with ONLY non-secret config (e.g.
# registry=https://registry.npmjs.org/), create it and un-ignore it below.
# NEVER store auth tokens in a tracked .npmrc file.
**/.npmrc

# Uncomment the next line to track a root-level .npmrc that contains ONLY
# non-secret configuration such as the registry URL. Verify it holds no
# _authToken, _password, or //registry credentials before committing.
# !.npmrc

# Yarn 2+ config may contain npmAuthToken entries
.yarnrc.yml

# pnpm store and auth config
.pnpmrc


# ──────────────────────────────────────────────────────────────────────────────
# 5. Node.js and Build Artifacts
#    Dependencies, compiled output, and incremental build caches.
# ──────────────────────────────────────────────────────────────────────────────

# Dependencies — never commit node_modules at any depth
**/node_modules/

# Build output directories
dist/
build/
# Next.js build output
.next/
# Next.js static export output
out/
# Turborepo cache
.turbo/
# Generic build caches
.cache/

# TypeScript incremental build info (large, machine-specific)
*.tsbuildinfo

# Parcel / Vite / Webpack caches
.parcel-cache/
.vite/


# ──────────────────────────────────────────────────────────────────────────────
# 6. Clarinet and Stacks Tooling
#    Local Clarinet state directories that may cache session keys.
# ──────────────────────────────────────────────────────────────────────────────

# Clarinet local state directory — may cache wallet keys from interactive sessions
.clarinet/

# Stacks node local data (if running a local node for development)
.stacks-node/
**/stacks-blockchain-data/

# Clarinet generated artifacts that may contain sensitive deployment info
**/history.txt


# ──────────────────────────────────────────────────────────────────────────────
# 7. IDE and OS Files
#    Editor configs, OS metadata, and swap files.
# ──────────────────────────────────────────────────────────────────────────────

# macOS Finder metadata
.DS_Store
**/.DS_Store

# Windows Explorer metadata
Thumbs.db
ehthumbs.db
desktop.ini

# JetBrains IDE (IntelliJ, WebStorm, etc.)
.idea/

# VS Code — exclude settings (may contain local paths/secrets) but keep
# extensions.json so the team shares recommended extensions
.vscode/*
!.vscode/extensions.json

# Vim/Neovim swap and backup files
*.swp
*.swo
*~
*.bak

# Sublime Text
*.sublime-workspace
*.sublime-project


# ──────────────────────────────────────────────────────────────────────────────
# 8. Logs and Debug Output
#    Application logs, crash reports, and heap dumps.
# ──────────────────────────────────────────────────────────────────────────────

# Generic log files
*.log

# npm / Yarn debug logs (numbered variants from retries)
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Crash reports and heap dump files
*.hprof
# Core dumps (Unix-style)
core.*

# Sentry / error tracking local caches
.sentryclirc


# ──────────────────────────────────────────────────────────────────────────────
# 9. Testing and Coverage Artifacts
#    Test runners, coverage reports, and result snapshots.
# ──────────────────────────────────────────────────────────────────────────────

# Code coverage output
coverage/
.nyc_output/

# Test result directories
test-results/
test-reports/

# Playwright / Cypress test artifacts
playwright-report/
cypress/screenshots/
cypress/videos/

# Jest cache
.jest-cache/


# ──────────────────────────────────────────────────────────────────────────────
# 10. Docker and Infrastructure Secrets
#     Local overrides, Terraform state, and any file whose name signals secrets.
# ──────────────────────────────────────────────────────────────────────────────

# Docker Compose override — commonly holds local secret overrides for databases,
# API keys, and service credentials that differ per developer
docker-compose.override.yml
docker-compose.override.yaml

# Terraform local state and variable files containing cloud credentials
.terraform/
*.tfvars
# Terraform state files (may contain resource secrets in plaintext)
*.tfstate
*.tfstate.backup

# ---- Catch-all patterns for files whose names signal secrets ----
# .gitignore does not support case-insensitive globs natively, so we list
# common casings to maximize coverage.

# Files containing "secret" in the name
*secret*
*Secret*
*SECRET*

# Files containing "credential" in the name
*credential*
*Credential*
*CREDENTIAL*

# Files containing "token" in the name (be specific to avoid false positives)
*_token
*_token.*
*_Token
*_Token.*
*.token
*.token.*

# Re-include legitimate files that match the catch-all patterns above
# (add entries here as needed for your project)
!.gitignore
!README.md
!PRD.md
# Re-include source code files that might match patterns (e.g. token-related modules)
!**/src/**
!**/lib/**
