# Normalize line endings to LF in the repository, regardless of the OS
# a developer checks out from. Git will convert to the native line ending
# on checkout (CRLF on Windows, LF on Mac/Linux) and back to LF on commit.
# This prevents spurious line-ending diffs when switching between platforms.

* text=auto eol=lf

# Explicitly mark shell scripts and source files as LF-only
*.sh        text eol=lf
*.bash      text eol=lf

# Clarity smart contracts
*.clar      text eol=lf

# TypeScript / JavaScript
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf

# Config and markup
*.json      text eol=lf
*.toml      text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.md        text eol=lf
*.mdx       text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.scss      text eol=lf
*.env       text eol=lf
*.env.*     text eol=lf
*.sql       text eol=lf

# Git-specific files
.gitignore          text eol=lf
.gitattributes      text eol=lf
.github/CODEOWNERS  text eol=lf

# Binary files — never touch line endings
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.svg   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.pdf   binary
*.zip   binary
*.tar   binary
*.gz    binary
