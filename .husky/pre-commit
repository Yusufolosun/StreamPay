# StreamPay Pre-commit Security Hooks
# Run checks in order, halt on first failure

# Get list of staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

echo "Running pre-commit security checks..."

# 1. Secret scanning
echo "  [1/5] Scanning for secrets..."
echo "$STAGED_FILES" | xargs node scripts/scan-secrets.js
if [ $? -ne 0 ]; then
  exit 1
fi

# 2. .env file guard
echo "  [2/5] Checking .env files..."
echo "$STAGED_FILES" | xargs node scripts/guard-env-files.js
if [ $? -ne 0 ]; then
  exit 1
fi

# 3. Mainnet TOML guard
echo "  [3/5] Checking TOML files..."
echo "$STAGED_FILES" | xargs node scripts/guard-mainnet-toml.js
if [ $? -ne 0 ]; then
  exit 1
fi

# 4. Large file guard
echo "  [4/5] Checking file sizes..."
echo "$STAGED_FILES" | xargs node scripts/guard-large-files.js
if [ $? -ne 0 ]; then
  exit 1
fi

echo "  [5/5] All pre-commit checks passed!"