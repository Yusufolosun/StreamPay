# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  ⚠️  WARNING: Copy to .env.local and fill in real values.                   ║
# ║      Never commit .env.local — it contains secrets!                         ║
# ║                                                                              ║
# ║  StreamPay Root Environment Variables                                       ║
# ║  Last updated: 2026-04-08                                                   ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ─────────────────────────────────────────────────────────────────────────────
# Stacks Network Configuration
# ─────────────────────────────────────────────────────────────────────────────

# Network to connect to: mainnet | testnet | devnet
STACKS_NETWORK=devnet

# Stacks API endpoint (leave empty for default)
STACKS_API_URL=

# ─────────────────────────────────────────────────────────────────────────────
# Hiro Platform (optional)
# ─────────────────────────────────────────────────────────────────────────────

# Hiro API key for higher rate limits (get one at platform.hiro.so)
HIRO_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Development Settings
# ─────────────────────────────────────────────────────────────────────────────

# Enable debug logging
DEBUG=false

# Development server port
PORT=3000
