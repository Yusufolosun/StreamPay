# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  ⚠️  WARNING: Copy to .env.local and fill in real values.                   ║
# ║      Never commit .env.local — it contains secrets!                         ║
# ║                                                                              ║
# ║  StreamPay Web Application Environment Variables                            ║
# ║  Last updated: 2026-04-08                                                   ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ─────────────────────────────────────────────────────────────────────────────────
# Stacks Network Configuration
# ─────────────────────────────────────────────────────────────────────────────────

# Network to connect to (Required)
# Values: mainnet | testnet | devnet
# Use devnet for local development, testnet for staging, mainnet for production
NEXT_PUBLIC_STACKS_NETWORK=devnet

# ─────────────────────────────────────────────────────────────────────────────────
# Smart Contract Addresses (Required)
# Format: SP/ST address.contract-name
# ─────────────────────────────────────────────────────────────────────────────────

# StreamPay Core contract — stream CRUD, rate engine, fee logic (Required)
# Devnet uses ST prefix, Mainnet uses SP prefix
NEXT_PUBLIC_STREAM_CORE_ADDRESS=ST1PQHQKV0RJXZFY1DGX8MNSNYVE3VGZJSRTPGZGM.stream-core

# StreamPay Conditions contract — milestones, arbiter, conditional release (Required)
# Must be deployed to the same network as stream-core
NEXT_PUBLIC_STREAM_CONDITIONS_ADDRESS=ST1PQHQKV0RJXZFY1DGX8MNSNYVE3VGZJSRTPGZGM.stream-conditions

# StreamPay NFT contract — SIP-009 receipts (Required)
# Must be deployed to the same network as stream-core
NEXT_PUBLIC_STREAM_NFT_ADDRESS=ST1PQHQKV0RJXZFY1DGX8MNSNYVE3VGZJSRTPGZGM.stream-nft

# ─────────────────────────────────────────────────────────────────────────────────
# Hiro API Configuration
# ─────────────────────────────────────────────────────────────────────────────────

# Hiro API base URL (Required)
# Devnet: http://localhost:3999
# Testnet: https://api.testnet.hiro.so
# Mainnet: https://api.mainnet.hiro.so
NEXT_PUBLIC_HIRO_API_URL=http://localhost:3999

# Hiro API key for higher rate limits (Optional)
# Get one at: https://platform.hiro.so
NEXT_PUBLIC_HIRO_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────────
# Application Configuration
# ─────────────────────────────────────────────────────────────────────────────────

# Application display name (Required)
NEXT_PUBLIC_APP_NAME=StreamPay
