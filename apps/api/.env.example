# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  ⚠️  WARNING: Copy to .env.local and fill in real values.                   ║
# ║      Never commit .env.local — it contains secrets!                         ║
# ║                                                                              ║
# ║  StreamPay API Server Environment Variables                                 ║
# ║  Last updated: 2026-04-08                                                   ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ─────────────────────────────────────────────────────────────────────────────────
# Server Configuration
# ─────────────────────────────────────────────────────────────────────────────────

# HTTP port the API server listens on (Required)
# Format: integer between 1-65535
# Default: 3001 (to avoid conflict with Next.js on 3000)
PORT=3001

# Node environment (Required)
# Values: development | test | production
# Controls: logging verbosity, error detail exposure, optimizations
NODE_ENV=development

# ─────────────────────────────────────────────────────────────────────────────────
# Stacks Network Configuration
# ─────────────────────────────────────────────────────────────────────────────────

# Stacks network to connect to (Required)
# Values: mainnet | testnet | devnet
# Must match the network where contracts are deployed
STACKS_NETWORK=devnet

# ─────────────────────────────────────────────────────────────────────────────────
# Hiro API Configuration
# ─────────────────────────────────────────────────────────────────────────────────

# Hiro API base URL (Required)
# Devnet: http://localhost:3999
# Testnet: https://api.testnet.hiro.so
# Mainnet: https://api.mainnet.hiro.so
HIRO_API_URL=http://localhost:3999

# Hiro API key for higher rate limits (Required for production)
# Get one at: https://platform.hiro.so
# NOTE: Server-side only — do NOT prefix with NEXT_PUBLIC_
HIRO_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────────
# Smart Contract Addresses
# Format: SP/ST address.contract-name
# ─────────────────────────────────────────────────────────────────────────────────

# StreamPay Core contract — stream CRUD, rate engine, fee logic (Required)
CONTRACT_STREAM_CORE=ST1PQHQKV0RJXZFY1DGX8MNSNYVE3VGZJSRTPGZGM.stream-core

# StreamPay Conditions contract — milestones, arbiter, conditional release (Required)
CONTRACT_STREAM_CONDITIONS=ST1PQHQKV0RJXZFY1DGX8MNSNYVE3VGZJSRTPGZGM.stream-conditions

# StreamPay NFT contract — SIP-009 receipts (Required)
CONTRACT_STREAM_NFT=ST1PQHQKV0RJXZFY1DGX8MNSNYVE3VGZJSRTPGZGM.stream-nft

# ─────────────────────────────────────────────────────────────────────────────────
# Database Configuration
# ─────────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string (Required)
# Format: postgresql://user:password@host:port/database?schema=public
# WARNING: Contains credentials — NEVER commit real values
DATABASE_URL=postgresql://postgres:password@localhost:5432/streampay?schema=public

# ─────────────────────────────────────────────────────────────────────────────────
# Authentication & Security
# ─────────────────────────────────────────────────────────────────────────────────

# JWT signing secret (Required)
# Must be at least 32 characters, cryptographically random
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WARNING: Compromising this secret invalidates all tokens
JWT_SECRET=

# ─────────────────────────────────────────────────────────────────────────────────
# CORS Configuration
# ─────────────────────────────────────────────────────────────────────────────────

# Allowed origins for CORS (Required)
# Format: comma-separated URLs, no trailing slashes
# Devnet: http://localhost:3000
# Production: https://your-domain.com
CORS_ORIGINS=http://localhost:3000
