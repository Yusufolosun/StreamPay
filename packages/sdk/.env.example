# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  WARNING: Copy to .env.local and fill in real values. Never commit .env.local.
# ║  StreamPay SDK Development & Testing Environment Variables
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ─────────────────────────────────────────────────────────────────────────────────
# SDK Test Network Configuration
# ─────────────────────────────────────────────────────────────────────────────────

# Network for SDK integration tests (Required for testing)
# Values: devnet | testnet
# NOTE: NEVER use mainnet for SDK tests
SDK_TEST_NETWORK=devnet

# ─────────────────────────────────────────────────────────────────────────────────
# Test Contract Configuration
# ─────────────────────────────────────────────────────────────────────────────────

# Contract address to use for SDK integration tests (Required for testing)
# Format: SP/ST address.contract-name
# Use devnet/testnet deployed contracts only
SDK_TEST_CONTRACT_ADDRESS=ST1PQHQKV0RJXZFY1DGX8MNSNYVE3VGZJSRTPGZGM.stream-core

# ─────────────────────────────────────────────────────────────────────────────────
# Test Wallet Configuration
# ─────────────────────────────────────────────────────────────────────────────────

# ███████████████████████████████████████████████████████████████████████████████
# ██  TESTNET ONLY — Private key for SDK integration tests                     ██
# ██                                                                           ██
# ██  This key is used to sign test transactions. Requirements:                ██
# ██  - Use ONLY testnet/devnet wallets (never mainnet)                        ██
# ██  - Generate a dedicated test wallet (not your personal wallet)            ██
# ██  - Fund with testnet STX from faucet: https://explorer.hiro.so/sandbox   ██
# ██                                                                           ██
# ██  Format: 64-character hex private key (no 0x prefix)                      ██
# ███████████████████████████████████████████████████████████████████████████████
#
SDK_TEST_PRIVATE_KEY=
